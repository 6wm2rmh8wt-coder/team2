PORT=3000
SESSION_SECRET=change-this-secret-in-production
DUR_API_KEY_ENCODED=your-encoded-service-key-from-data.go.kr

# Vercel Postgres(Neon) 연결 - Vercel 대시보드의 Storage 탭에서 Postgres 생성 시 자동 발급됩니다.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Vercel Blob - Vercel 대시보드의 Storage 탭에서 Blob 생성 시 자동 발급됩니다.
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
